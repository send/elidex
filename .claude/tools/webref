#!/usr/bin/env python3
"""webref lookup helper — spec citation verification for elidex.

Backs the Axis 4 (Spec citation discipline) verification recipe in
.claude/skills/elidex-review/axes.md. Resolves section numbers, anchor IDs,
WebIDL fragments, concept dfn anchors, element-to-interface mappings, and CSS
property metadata against w3c/webref (machine-readable extracts of WHATWG /
W3C specs). More reliable than WebFetch on spec HTML, which truncates on long
documents — webref ships per-spec JSON / IDL that fits in one fetch + grep.

For tc39 specs (ECMA-262 / ECMA-402) the source is the tc39-published
biblio JSON (`@tc39/ecma262-biblio`, `@tc39/ecma402-biblio` on npm; served
via jsdelivr CDN). One file per spec, 4500+ entries, carries `number` /
`title` / `id` / `aoid` / `kind` / `signature` etc. — strictly better than
scraping the rendered HTML. All upstream fetches share a single
~/.cache/elidex-webref/ HTTP cache (ETag + Last-Modified).

Subcommands:
  heading      <spec> <number-prefix>   §number → title + anchor
  idl          <spec> <interface>       interface IDL fragment
  dfn          <spec> <term>            concept dfn → §heading + anchor
  element      <spec> <element-name>    HTML/SVG element → interface name + href
  css          <spec> <name>            CSS property / @rule / selector / value metadata
  aoid         <spec> <name>            (tc39) abstract operation aoid → §number + anchor
  specs        <keyword>                shortname lookup (by spec title)
  coverage-map <spec> <ref> ...         plan-memo §3 Spec coverage map skeleton + breadth verdict
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
import re
import sys
import urllib.error
import urllib.request
from pathlib import Path

BASE = "https://raw.githubusercontent.com/w3c/webref/main/ed"

