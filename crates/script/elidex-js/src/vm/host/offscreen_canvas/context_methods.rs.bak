fn native_oc_move_to(
    ctx: &mut NativeContext<'_>,
    this: JsValue,
    args: &[JsValue],
) -> Result<JsValue, VmError> {
    let (x, y) = (arg_f32(ctx, args, 0)?, arg_f32(ctx, args, 1)?);
    dispatch_2d_method(
        ctx,
        this,
        "moveTo",
        false,
        require_offscreen_canvas_2d_context,
        |c| c.move_to(x, y),
    )?;
    Ok(JsValue::Undefined)
}

