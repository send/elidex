# Rust build artifacts
/target/
**/*.rs.bk

# Editor files
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db

# Crawler output
output/
output-*/

# Environment
.env

# Local cargo config (sccache etc.)
.cargo/config.toml

# Claude Code — settings/state は untracked、shared skills + tools のみ tracked
.claude/*
!.claude/skills/
!.claude/tools/

# Python bytecode (.claude/tools/_webref/ is a Python package)
__pycache__/
*.pyc

rust_out
